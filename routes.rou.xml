<?xml version="1.0" encoding="UTF-8"?>
<routes>
    <!--
      Define a generic car type with highly optimized parameters for maximum performance
    -->
    <vType id="car" 
           accel="2.6" 
           decel="4.5" 
           sigma="0.5" 
           maxSpeed="13.9" 
           length="5.0" 
           minGap="2.5" 
           tau="1.0"
           speedDev="0.1"
           speedFactor="1.1"
           lcSpeedGain="1.0"
           lcKeepRight="1.0"/>

    <!--
      Define four routes through the intersection:
        • NS: North → Center → South
        • SN: South → Center → North
        • EW: East  → Center → West
        • WE: West  → Center → East
      These edge IDs must match exactly what you used in edges.edg.xml (and thus in intersection.net.xml):
      N2C, C2S, S2C, C2N, E2C, C2W, W2C, C2E
    -->
    <route id="NS" edges="N2C C2S"/>
    <route id="SN" edges="S2C C2N"/>
    <route id="EW" edges="E2C C2W"/>
    <route id="WE" edges="W2C C2E"/>

    <!--
      Reduced number of vehicles and adjusted timing for better performance
    -->
    <flow id="flow_NS" route="NS" type="car" begin="0" end="300" number="25"/>
    <flow id="flow_SN" route="SN" type="car" begin="0" end="300" number="25"/>
    <flow id="flow_EW" route="EW" type="car" begin="0" end="300" number="25"/>
    <flow id="flow_WE" route="WE" type="car" begin="0" end="300" number="25"/>
</routes>

